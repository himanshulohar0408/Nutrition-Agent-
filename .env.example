# ─────────────────────────────────────────────────────────
#  AI Nutrition Agent — Environment Variables
#  Copy this file to .env and fill in your credentials
# ─────────────────────────────────────────────────────────

# IBM Watsonx.ai credentials
# Get from: https://cloud.ibm.com/iam/apikeys
IBM_API_KEY=your_ibm_api_key_here

# IBM Watsonx.ai Project ID
# Get from: https://dataplatform.cloud.ibm.com → Your Project → Manage → General
IBM_PROJECT_ID=your_project_id_here

# IBM Watsonx.ai endpoint (region-specific)
# us-south: https://us-south.ml.cloud.ibm.com
# eu-de:    https://eu-de.ml.cloud.ibm.com
# jp-tok:   https://jp-tok.ml.cloud.ibm.com
IBM_URL=https://us-south.ml.cloud.ibm.com

# Flask settings
FLASK_SECRET_KEY=change-this-to-a-random-secret-string-in-production
FLASK_DEBUG=false
PORT=5000
